#!/usr/bin/env sh
#
# pre-push — sync dotfiles to Mac after push
#
# Mirrors cc's pattern: background SSH pull with delay
# so the push completes before the remote fetches.
# chezmoi apply is explicit since git reset --hard
# doesn't trigger post-merge hooks.

# After successful push from Arch: sync Mac in background
if [ "$(hostname)" = "omarchy" ]; then
    (sleep 2 && ssh mac "cd ~/dev/if && git fetch origin main -q && git reset --hard origin/main -q && chezmoi apply --no-tty 2>/dev/null; true" &) 2>/dev/null
fi

exit 0
