#!/bin/sh
#
# chezmoi-apply — deploy dotfiles after git operations
#
# Called by post-merge and post-commit hooks to keep deployed
# config (~/.zshrc, ~/.config/*, etc.) in sync with source.

if ! command -v chezmoi >/dev/null 2>&1; then
    exit 0
fi

# Verify this repo is the chezmoi source directory
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"
CHEZMOI_SOURCE="$(chezmoi source-path 2>/dev/null)"

if [ "$REPO_ROOT" != "$CHEZMOI_SOURCE" ]; then
    exit 0
fi

# Apply changes (non-interactive, skip prompts)
if chezmoi apply --no-tty 2>/dev/null; then
    echo "chezmoi: applied dotfiles"
else
    echo "chezmoi: apply failed (run 'chezmoi apply' manually)" >&2
fi

exit 0
