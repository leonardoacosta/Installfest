#!/bin/sh
# tmux-nexus-creds — tmux status-right helper
# Queries nexus-agent for active credential usage, outputs tmux-formatted string.
# Called every ~2s by tmux via #(tmux-nexus-creds). Outputs nothing on failure.

DIM="#454D54"
CYAN="#5BD1B9"
YELLOW="#FAC760"
RED="#E61F44"

json=$(curl -sf --max-time 1 http://localhost:7402/credentials) || exit 0

active=$(printf '%s' "$json" | jq -r '.active_account // empty') || exit 0
[ -z "$active" ] && exit 0

acct=$(printf '%s' "$json" | jq -r --arg name "$active" '.accounts[] | select(.name == $name)') || exit 0
[ -z "$acct" ] && exit 0

util_5h=$(printf '%s' "$acct" | jq -r '.five_hour.utilization // empty')
util_7d=$(printf '%s' "$acct" | jq -r '.seven_day.utilization // empty')

color_for() {
  if [ -z "$1" ]; then
    echo "$DIM"
  elif [ "$(echo "$1 > 0.80" | bc)" = "1" ]; then
    echo "$RED"
  elif [ "$(echo "$1 >= 0.50" | bc)" = "1" ]; then
    echo "$YELLOW"
  else
    echo "$CYAN"
  fi
}

pct_for() {
  if [ -z "$1" ]; then
    echo "--"
  else
    printf '%.0f%%' "$(echo "$1 * 100" | bc)"
  fi
}

c5=$(color_for "$util_5h")
c7=$(color_for "$util_7d")
p5=$(pct_for "$util_5h")
p7=$(pct_for "$util_7d")

printf '#[fg=%s]%s #[fg=%s]5H:#[fg=%s]%s#[default] #[fg=%s]7D:#[fg=%s]%s#[default]' \
  "$DIM" "$active" "$DIM" "$c5" "$p5" "$DIM" "$c7" "$p7"
