// Zed settings — managed by chezmoi
// Mirrors the load-bearing parts of the previous Cursor settings:
//   font, format-on-save, watcher excludes, prettier defaults.
// Bicep support: auto-installed extension uses the `bicep` CLI from Homebrew.
// Live-reload static dev: install `live-server` globally (see run_once_install-packages.sh.tmpl).
{
  "telemetry": {
    "metrics": false,
    "diagnostics": false
  },

  // === Editor ===
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_size": 14,
  "buffer_font_features": { "calt": true },
  "ui_font_family": "JetBrainsMono Nerd Font",
  "ui_font_size": 14,
  "format_on_save": "on",
  "formatter": "prettier",
  "tab_size": 2,
  "soft_wrap": "editor_width",
  "show_whitespaces": "selection",
  "preferred_line_length": 100,

  // === Theme ===
  // One Hunter Vercel matches the Ghostty + tmux palette already in this
  // dotfiles repo (home/dot_config/ghostty/themes/One-Hunter-Vercel).
  // The "one-hunter" extension is auto-installed below; ships 6 variants:
  //   One Hunter Light, Classic, Flexokit Light, Flexoki Dark, Material, Vercel.
  "theme": {
    "mode": "dark",
    "light": "One Hunter Light",
    "dark": "One Hunter Vercel"
  },

  // === Git ===
  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": { "enabled": true, "delay_ms": 600 }
  },

  // === Auto-install required extensions ===
  //   bicep      — ARM template authoring (binary at ~/.local/bin/bicep)
  //   one-hunter — One Hunter theme family (incl. One Hunter Vercel)
  "auto_install_extensions": {
    "bicep": true,
    "one-hunter": true
  },

  // === AI: Edit Predictions (Zed's native copilot) ===
  // Free with a Zed account; sign in via Cmd+Shift+P → "zed: sign in".
  // Set to "copilot" for GitHub Copilot, "supermaven" for Supermaven.
  "features": {
    "edit_predictions_provider": "zed"
  },
  "show_edit_predictions": true,

  // === AI: Assistant panel + inline edits (Cmd+I) ===
  // Anthropic enabled — same key you use for Claude Code.
  // Zed prompts for ANTHROPIC_API_KEY on first use (or reads from env).
  // Pick the active model from the assistant panel dropdown — Zed's known-
  // models list updates per release, so we don't pin a default here.
  "assistant": {
    "version": "2",
    "enabled": true,
    "button": true
  },
  "language_models": {
    "anthropic": {
      "version": "1"
    }
  },

  // === Context Servers (MCP) ===
  // Zed connects to MCP servers the same way Claude Code does. To wire one,
  // add an entry below — e.g. beads, github, sentry — using the same command
  // and env you use in ~/.claude/mcp_servers.json. Left empty for now to
  // avoid forcing a configuration; populate as needed.
  "context_servers": {},

  // === Per-language formatters / settings ===
  "languages": {
    "TypeScript": { "formatter": "prettier", "format_on_save": "on" },
    "TSX": { "formatter": "prettier", "format_on_save": "on" },
    "JavaScript": { "formatter": "prettier", "format_on_save": "on" },
    "JSX": { "formatter": "prettier", "format_on_save": "on" },
    "JSON": { "formatter": "prettier", "format_on_save": "on" },
    "JSONC": { "formatter": "prettier", "format_on_save": "on" },
    "YAML": { "formatter": "prettier", "format_on_save": "on" },
    "Markdown": { "formatter": "prettier", "format_on_save": "on", "soft_wrap": "preferred_line_length" },
    "HTML": { "formatter": "prettier", "format_on_save": "on" },
    "CSS": { "formatter": "prettier", "format_on_save": "on" },
    "Bicep": { "format_on_save": "on" }
  },

  // === LSP server config ===
  "lsp": {
    // Bicep — extension wires this automatically; explicit fallback in case
    // the extension fails to load. Binary lives at ~/.local/bin/bicep
    // (symlinked from ~/.azure/bin/bicep, installed via az bicep install).
    "bicep-langserver": {
      "binary": {
        "path": "bicep",
        "arguments": ["langserver"]
      }
    },

    // TypeScript — bound memory at 1.5 GB to keep remote-server resident set
    // under control on t3 turbo monorepos. Without this, tsserver routinely
    // balloons to 2-3 GB on projects with 10+ packages sharing types (oo,
    // tc, etc.). Mirrors the prior Cursor setting (typescript.tsserver
    // .maxTsServerMemory: 1536). includePackageJsonAutoImports is the most
    // expensive auto-feature in tsserver — disabling it saves ~30% memory
    // and removes auto-import suggestions from package.json scanning (Zed's
    // own auto-import via tree-sitter still works for imports already in
    // the project).
    "typescript-language-server": {
      "initialization_options": {
        "maxTsServerMemory": 1536,
        "preferences": {
          "includePackageJsonAutoImports": "off"
        }
      }
    }
  },

  // === File scan / search excludes ===
  // Mirrors the Cursor watcher/search excludes — keeps file tree fast on T3 monorepos.
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    "**/node_modules",
    "**/.next",
    "**/.turbo",
    "**/.cursor-server",
    "**/.vscode-server",
    "**/.zed-server",
    "**/.cargo",
    "**/.cache",
    "**/.npm",
    "**/.bun",
    "**/.pnpm-store",
    "**/dist",
    "**/build",
    "**/.expo"
  ],

  // === Terminal (integrated) ===
  // Inherits zsh from login shell; keeps the same JetBrainsMono font as Ghostty.
  "terminal": {
    "shell": { "program": "zsh" },
    "font_family": "JetBrainsMono Nerd Font",
    "font_size": 14,
    "working_directory": "current_project_directory"
  },

  // === Misc ===
  "vim_mode": false,
  "autosave": "off",
  "restore_on_startup": "last_session",
  "remove_trailing_whitespace_on_save": true,
  "ensure_final_newline_on_save": true,
  "tabs": { "git_status": true, "file_icons": true }
}
