format = """
[](fg:#5278C4)\
$os\
[](fg:#5278C4 bg:#5099C4)\
$directory\
[](fg:#5099C4 bg:#2A2D44)\
$git_branch\
$git_status\
[](fg:#2A2D44 bg:#1A1B26)\
$python\
$lua\
$nodejs\
$dotnet\
$golang\
$haskell\
$rust\
$ruby\
$azure\
$aws\
$docker_context\
$jobs\
$cmd_duration\
[](fg:#1A1B26)\
$line_break\
$character"""

add_newline = true
palette = "{{ .theme }}"

[os]
disabled = false
style = 'bg:#5278C4 fg:#0D0E15'
format = '[ $symbol ]($style)'

[os.symbols]
Macos = ""
Linux = ""
Arch = ""

[hostname]
ssh_only = true
format = "[@$hostname]($style) "
style = "bold dimmed white"

[directory]
style = 'fg:#0D0E15 bg:#5099C4'
format = '[ $path ]($style)'
truncation_length = 3
truncation_symbol = '…/'
truncate_to_repo = false

[directory.substitutions]
'Documents' = '󰈙'
'Downloads' = ' '
'Music' = ' '
'Pictures' = ' '

[git_branch]
symbol = ''
style = 'bg:#2A2D44'
format = '[[ $symbol $branch ](fg:#9AA3C4 bg:#2A2D44)]($style)'

[git_status]
style = 'bg:#2A2D44'
format = '[[($all_status$ahead_behind )](fg:#C4546E bg:#2A2D44)]($style)'

[fill]
symbol = ' '

[python]
symbol = ''
style = 'bg:#1A1B26'
format = '[[ $symbol ${pyenv_prefix}(${version} )(\($virtualenv\) )](fg:#4EA596 bg:#1A1B26)]($style)'
pyenv_version_name = true
pyenv_prefix = ''

[lua]
symbol = ''
style = 'bg:#1A1B26'
format = '[[ $symbol ($version) ](fg:#5278C4 bg:#1A1B26)]($style)'

[nodejs]
symbol = ''
style = 'bg:#1A1B26'
format = '[[ $symbol ($version) ](fg:#5278C4 bg:#1A1B26)]($style)'

[dotnet]
symbol = ''
style = 'bg:#1A1B26'
format = '[[ $symbol ($version) ](fg:#8E6DC4 bg:#1A1B26)]($style)'

[golang]
symbol = ''
style = 'bg:#1A1B26'
format = '[[ $symbol ($version) ](fg:#5099C4 bg:#1A1B26)]($style)'

[haskell]
symbol = ''
style = 'bg:#1A1B26'
format = '[[ $symbol ($version) ](fg:#8E6DC4 bg:#1A1B26)]($style)'

[rust]
symbol = ''
style = 'bg:#1A1B26'
format = '[[ $symbol ($version) ](fg:#C97A4A bg:#1A1B26)]($style)'

[ruby]
symbol = ''
style = 'bg:#1A1B26'
format = '[[ $symbol ($version) ](fg:#C4546E bg:#1A1B26)]($style)'

[package]
symbol = '󰏗 '

[azure]
style = 'bg:#1A1B26'
format = '[[ $symbol ($subscription) ](fg:#5278C4 bg:#1A1B26)]($style)'

[aws]
symbol = ''
style = 'bg:#1A1B26'
format = '[[ $symbol ($profile )(\[$duration\] )](fg:#A87F4A bg:#1A1B26)]($style)'

[docker_context]
symbol = ''
style = 'bg:#1A1B26'
format = '[[ $symbol $context ](fg:#4EA596 bg:#1A1B26)]($style)'
detect_files = ['docker-compose.yml', 'docker-compose.yaml', 'Dockerfile', 'compose.yml', 'compose.yaml']
detect_extensions = []

[jobs]
symbol = ''
style = 'bg:#1A1B26'
number_threshold = 1
format = '[[ $symbol ](fg:#C4546E bg:#1A1B26)]($style)'

[cmd_duration]
min_time = 500
style = 'bg:#1A1B26'
format = '[[  $duration ](fg:#A87F4A bg:#1A1B26)]($style)'

[character]
success_symbol = '[❯](fg:#729947)'
error_symbol = '[❯](fg:#C4546E)'

