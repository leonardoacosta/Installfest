#!/usr/bin/env zsh
# .zshrc - Entry point for interactive zsh sessions
# Managed by chezmoi: ~/.zshrc

# Ensure DOTFILES is set (should be set by .zshenv)
export DOTFILES="${DOTFILES:-$HOME/dev/if}"

# Auto-attach tmux on SSH (prevents mouse escape leak from local tmux)
if [[ -n "$SSH_CONNECTION" && -z "$TMUX" && -z "$VSCODE_TERMINAL" ]]; then
  tmux new-session -A -s "${PWD##*/}"
fi


# Load secrets via Doppler (falls back to ~/.env if Doppler unavailable)
if command -v doppler &>/dev/null; then
  eval "$(doppler secrets download --no-file --format env 2>/dev/null)"
elif [[ -f "$HOME/.env" ]]; then
  set -a
  source "$HOME/.env"
  set +a
fi

# Load shared configuration (history opts, aliases, settings)
source "$HOME/.zsh/rc/shared.zsh"

# Load platform-specific configuration
case "$(uname -s)" in
  Darwin)
    source "$HOME/.zsh/rc/darwin.zsh"
    ;;
  Linux)
    source "$HOME/.zsh/rc/linux.zsh"
    ;;
esac

# Load functions (order matters!)
source "$HOME/.zsh/functions/setup-completions.zsh"  # compinit, fpath
source "$HOME/.zsh/functions/load-plugins.zsh"       # syntax-hl, autosuggestions
source "$HOME/.zsh/functions/load-tools.zsh"         # zoxide, atuin, fzf, etc.
source "$HOME/.zsh/functions/init-starship.zsh"      # prompt (load last)

# Neutralize Cursor/VS Code shell integration on SSH sessions
# Cursor installs __vsc_precmd/__vsc_preexec hooks that emit \e]633;... sequences.
# When CC takes over the terminal, Cursor stops seeing these markers and writes
# "source .../shellIntegration-rc.zsh" directly to stdin — polluting CC's input.
# Removing the hooks prevents the marker→re-inject cycle on remote sessions.
# Local Cursor terminals (non-SSH) are unaffected.
if [[ "$TERM_PROGRAM" == "vscode" && -n "$SSH_CONNECTION" ]]; then
  precmd_functions=(${precmd_functions:#__vsc_*})
  preexec_functions=(${preexec_functions:#__vsc_*})
fi
