#!/usr/bin/env bash
# run_once_install-packages.sh - chezmoi run_once package installer
# Runs once per machine (chezmoi tracks by content hash)

set -uo pipefail
# Note: -e intentionally omitted — brew bundle may return non-zero
# for already-installed casks or optional failures that shouldn't abort

DOTFILES="{{ .chezmoi.sourceDir }}"
export DOTFILES

# Source utilities
. "$DOTFILES/scripts/utils.sh"

info "========================================"
info "  Dotfiles Package Installer (chezmoi)"
info "  Platform: $(uname -s) ($(uname -m))"
info "  Source:   $DOTFILES"
info "========================================"
echo

{{ if eq .chezmoi.os "darwin" -}}
info "Detected macOS"

# Source Mac prerequisites
. "$DOTFILES/scripts/prerequisites.sh"
. "$DOTFILES/scripts/brew-install.sh"
. "$DOTFILES/scripts/osx-defaults.sh"
. "$DOTFILES/scripts/terminal.sh"

# Core packages (non-interactive — chezmoi run_once must complete without prompts)
install_xcode
install_homebrew
run_brew_bundle || warning "brew bundle had errors (some casks may need manual install)"

# macOS system defaults
apply_osx_system_defaults || warning "Some macOS defaults failed (non-fatal)"

# Terminal setup
terminal || true

# Load mic-priority LaunchAgent
if [[ -f "$HOME/Library/LaunchAgents/com.leonardoacosta.mic-priority.plist" ]]; then
    chmod +x "$DOTFILES/scripts/mic-priority.sh" 2>/dev/null || true
    if ! launchctl list | grep -q "com.leonardoacosta.mic-priority"; then
        launchctl bootstrap "gui/$(id -u)" "$HOME/Library/LaunchAgents/com.leonardoacosta.mic-priority.plist" 2>/dev/null || true
        success "Loaded mic-priority LaunchAgent"
    fi
fi

{{ else if eq .chezmoi.os "linux" -}}
info "Detected Linux"

# Check if Arch Linux
if [[ -f /etc/arch-release ]]; then
    . "$DOTFILES/scripts/install-arch.sh"
else
    warning "Non-Arch Linux detected. Package install skipped."
    warning "Install zsh plugins manually for your distribution."
fi

{{ end -}}

# === Final messages ===
echo
success "========================================"
success "  Package Installation Complete!"
success "========================================"
echo
info "Next steps:"
info "  1. Run 'chezmoi apply' to deploy dotfiles"
info "  2. Restart your terminal or run: source ~/.zshrc"
info "  3. Verify starship prompt is working"
info "  4. Run 'z --help' to learn zoxide"
info "  5. Run 'atuin login' to sync history (optional)"
echo
