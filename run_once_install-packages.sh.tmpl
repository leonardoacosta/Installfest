#!/usr/bin/env bash
# run_once_install-packages.sh - chezmoi run_once package installer
# Runs once per machine (chezmoi tracks by content hash)

set -uo pipefail
# Note: -e intentionally omitted — brew bundle may return non-zero
# for already-installed casks or optional failures that shouldn't abort

DOTFILES="{{ .chezmoi.sourceDir }}"
export DOTFILES

# Source utilities
. "$DOTFILES/scripts/utils.sh"

info "========================================"
info "  Dotfiles Package Installer (chezmoi)"
info "  Platform: $(uname -s) ($(uname -m))"
info "  Source:   $DOTFILES"
info "========================================"
echo

{{ if eq .chezmoi.os "darwin" -}}
info "Detected macOS"

# Source Mac prerequisites
. "$DOTFILES/scripts/prerequisites.sh"
. "$DOTFILES/scripts/brew-install.sh"
. "$DOTFILES/scripts/osx-defaults.sh"
. "$DOTFILES/scripts/terminal.sh"

# Core packages (non-interactive — chezmoi run_once must complete without prompts)
install_xcode
install_homebrew
run_brew_bundle || warning "brew bundle had errors (some casks may need manual install)"

# macOS system defaults
apply_osx_system_defaults || warning "Some macOS defaults failed (non-fatal)"

# Terminal setup
terminal || true

# Install ProxyBridge (per-app SOCKS5 proxy for Microsoft CAE bypass)
if [[ ! -d "/Applications/ProxyBridge.app" ]]; then
    PROXYBRIDGE_VERSION="3.2.0"
    PROXYBRIDGE_PKG="/tmp/ProxyBridge.pkg"
    info "Installing ProxyBridge v${PROXYBRIDGE_VERSION}..."
    curl -Lo "$PROXYBRIDGE_PKG" "https://github.com/InterceptSuite/ProxyBridge/releases/download/v${PROXYBRIDGE_VERSION}/ProxyBridge-v${PROXYBRIDGE_VERSION}-Universal-Installer.pkg"
    sudo installer -pkg "$PROXYBRIDGE_PKG" -target / && success "ProxyBridge installed" || warning "ProxyBridge install failed (may need manual install)"
    rm -f "$PROXYBRIDGE_PKG"
    info "NOTE: Approve ProxyBridge Network Extension on first launch:"
    info "  System Settings → General → Login Items & Extensions → Network Extensions"
    info "Import proxy rules from: $DOTFILES/scripts/proxybridge-rules.json"
else
    success "ProxyBridge already installed"
fi

# Load LaunchAgents
for plist_name in com.leonardoacosta.cloudpc-tunnel; do
    plist="$HOME/Library/LaunchAgents/${plist_name}.plist"
    if [[ -f "$plist" ]] && ! launchctl list | grep -q "$plist_name"; then
        launchctl bootstrap "gui/$(id -u)" "$plist" 2>/dev/null || true
        success "Loaded $plist_name LaunchAgent"
    fi
done

# Load mic-priority LaunchAgent
if [[ -f "$HOME/Library/LaunchAgents/com.leonardoacosta.mic-priority.plist" ]]; then
    chmod +x "$DOTFILES/scripts/mic-priority.sh" 2>/dev/null || true
    if ! launchctl list | grep -q "com.leonardoacosta.mic-priority"; then
        launchctl bootstrap "gui/$(id -u)" "$HOME/Library/LaunchAgents/com.leonardoacosta.mic-priority.plist" 2>/dev/null || true
        success "Loaded mic-priority LaunchAgent"
    fi
fi

{{ else if eq .chezmoi.os "linux" -}}
info "Detected Linux"

# Check if Arch Linux
if [[ -f /etc/arch-release ]]; then
    . "$DOTFILES/scripts/install-arch.sh"
else
    warning "Non-Arch Linux detected. Package install skipped."
    warning "Install zsh plugins manually for your distribution."
fi

# Enable systemd user services (file-server + cloudpc tunnel)
if command -v systemctl &>/dev/null; then
    for svc in file-server cloudpc-tunnel; do
        if [[ -f "$HOME/.config/systemd/user/${svc}.service" ]]; then
            systemctl --user enable "$svc" 2>/dev/null && success "Enabled $svc service" || true
        fi
    done
    systemctl --user daemon-reload 2>/dev/null || true
fi

{{ end -}}

# === Git hooks (all platforms) ===
if [[ -d "$DOTFILES/.git" ]]; then
    git -C "$DOTFILES" config core.hooksPath scripts/hooks
    success "Set git hooks path to scripts/hooks/"
fi

# === Final messages ===
echo
success "========================================"
success "  Package Installation Complete!"
success "========================================"
echo
info "Next steps:"
info "  1. Run 'chezmoi apply' to deploy dotfiles"
info "  2. Restart your terminal or run: source ~/.zshrc"
info "  3. Verify starship prompt is working"
info "  4. Run 'z --help' to learn zoxide"
info "  5. Run 'atuin login' to sync history (optional)"
echo
