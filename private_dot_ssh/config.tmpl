# SSH Config — managed by chezmoi
# Machine: {{ .machine }} ({{ .chezmoi.hostname }})

{{ if eq .machine "mac" -}}
# Homelab - Smart routing: LAN first, Tailscale fallback
# macOS nc -w doesn't timeout connections, use bash /dev/tcp with timeout
Match host homelab exec "bash -c 'exec 3<>/dev/tcp/192.168.1.100/22' 2>/dev/null & pid=$!; sleep 0.5; kill $pid 2>/dev/null && exit 1; wait $pid 2>/dev/null"
    HostName 192.168.1.100
    User nyaptor
    IdentityFile ~/.ssh/id_ed25519

Host homelab
    HostName homelab.tail296462.ts.net
    User nyaptor
    IdentityFile ~/.ssh/id_ed25519

{{ else if eq .machine "homelab" -}}
Host mac
    HostName 100.91.88.16
    User leonardoacosta
    IdentityFile ~/.ssh/id_ed25519
    ServerAliveInterval 60
    ServerAliveCountMax 3
    ConnectTimeout 10

{{ end -}}
# CloudPC via Tailscale (all machines)
Host cloudpc
    HostName 100.83.148.5
    User leo
    IdentityFile ~/.ssh/id_ed25519

# Global settings
Host *
    SendEnv LANG LC_*
    SetEnv TERM=xterm-256color
    AddKeysToAgent yes
    ServerAliveInterval 30
    ServerAliveCountMax 3
    ConnectionAttempts 2
    ConnectTimeout 10
