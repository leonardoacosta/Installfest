{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
  "version": "0.2",
  "language": "en",
  "description": "Global cSpell dictionary — deployed by chezmoi to ~/.config/cspell/cspell.json. Per-repo cspell.json files merge with this.",
  "words": [
    "Accelevents",
    "Acosta",
    "beads",
    "bicep",
    "chezmoi",
    "drizzle",
    "Eventbrite",
    "Ghostty",
    "HMAC",
    "homelab",
    "HOTSPOT",
    "leonardoacosta",
    "Mailchimp",
    "openspec",
    "OTAKU",
    "POSTHOG",
    "ralphwiggum",
    "starship",
    "tRPC",
    "turborepo",
    "Vercel",
    "waitlist",
    "waitlisted",
    "WCAG",
    "Whova",
    "Workgroups",
    "Zoomable"
  ],
  "ignorePaths": [
    "node_modules/**",
    ".next/**",
    ".turbo/**",
    "dist/**",
    "coverage/**",
    "**/pnpm-lock.yaml",
    "**/package-lock.json"
  ]
}
